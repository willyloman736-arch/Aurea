# ============================================
# Aurea environment — copy to .env.local
# ============================================

# ---------- Phase 2 — real tracking ----------

# EasyPost API key (Test key is free & unlimited for development)
# → https://www.easypost.com/account/api-keys
# Test keys start with "EZTK..." and simulate carrier responses.
# Production keys start with "EZAK..." and hit live carriers.
EASYPOST_API_KEY=EZTK_your_test_key_here

# Optional — sign incoming webhooks
# Set this in your EasyPost webhook config, then paste same value here.
EASYPOST_WEBHOOK_SECRET=

# Neon Postgres (free tier: 0.5 GB, always-on)
# → https://console.neon.tech → create project → copy connection string
# Use the pooled connection string for serverless.
DATABASE_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/aurea?sslmode=require"

# ---------- Phase 3 — auth (Clerk) ----------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ---------- Notes ----------
# Do NOT commit .env.local — it is .gitignored.
# Set the same vars in Vercel project settings before deploy.

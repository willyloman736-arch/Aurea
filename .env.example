# ============================================
# Aurea environment — copy to .env.local
# ============================================

# Phase 2 — carrier tracking (EasyPost)
# Get from https://www.easypost.com/account/api-keys
EASYPOST_API_KEY=

# Phase 2 — Neon Postgres (via Prisma)
# Get from https://console.neon.tech
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Phase 3 — Clerk authentication
# Get from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Phase 4 — deploy
# Set in Vercel project settings, not here
# VERCEL_URL is injected automatically

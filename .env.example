# ============================================
# Aurea environment — copy to .env.local
# ============================================

# Public site URL used in receipt/tracking links sent to clients.
NEXT_PUBLIC_SITE_URL=https://usps-s.com

# ---------- Phase 2 — real tracking (Shippo) ----------

# Shippo API token (Test keys start with `shippo_test_…`, free & unlimited).
# Get one at https://apps.goshippo.com/settings/api
# Live keys require manual approval — email Shippo's API team.
SHIPPO_API_KEY=shippo_test_your_key_here

# Optional — long random string to authenticate incoming webhooks.
# Generate with:  openssl rand -hex 32
# Then set your Shippo webhook URL to:
#   https://<your-domain>/api/webhooks/shippo?token=<this-value>
SHIPPO_WEBHOOK_SECRET=

# ---------- Phase 2 — Neon Postgres ----------

# Pooled connection string from https://console.neon.tech
# Free tier: 0.5 GB, always-on, autoscaling compute.
DATABASE_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/aurea?sslmode=require"

# ---------- Phase 3 — auth (Clerk) ----------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ---------- Notes ----------
# Do NOT commit .env.local — it is .gitignored.
# Set the same vars in Vercel project settings before deploy.
